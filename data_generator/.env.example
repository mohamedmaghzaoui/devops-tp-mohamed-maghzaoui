# =========================
# Django Core
# =========================

DEBUG=            # Example: True (development) / False (production)
SECRET_KEY=       # Example: your-django-secret-key
ALLOWED_HOSTS=    # Example: localhost,127.0.0.1,yourdomain.com

# =========================
# CORS
# =========================

CORS_ALLOWED_ORIGINS=  # Example: http://localhost:5173,https://yourfrontend.com

# =========================
# Database
# =========================

DB_NAME=          # Example: AIGen or your_database_name
DB_USER=          # Example: postgres
DB_PASSWORD=      # Example: your_secure_password
DB_HOST=          # Example: localhost or db (docker)
DB_PORT=          # Example: 5432

# =========================
# AI (Google Gemini)
# =========================

GEMINI_API_KEY=   # Example: your_gemini_api_key_here